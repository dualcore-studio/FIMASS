# InstantDB (obbligatorio in produzione)
INSTANT_APP_ID=
INSTANT_ADMIN_TOKEN=

# Autenticazione JWT
JWT_SECRET=

# Email transazionali (Resend)
# API key dalla dashboard Resend. Il mittente DEVE essere di un dominio verificato in Resend
# (DNS SPF/DKIM). In alternativa solo per prove locali: onboarding@resend.dev (limitato).
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# URL pubblico del frontend (per link nelle email, es. https://portale.example.com)
APP_URL=
